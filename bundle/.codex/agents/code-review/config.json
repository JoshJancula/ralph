{
  "name": "code-review",
  "description": "reviews code",
  "model": "gpt-5.1-codex-mini",
  "rules": [".codex/rules/no-emoji.md"],
  "skills": [".codex/skills/repo-context/SKILL.md"],
  "output_artifacts": [
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/code-review.md",
      "required": true,
      "kind": "review"
    },
    {
      "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/code-review-to-implementation.md",
      "required": false,
      "kind": "handoff",
      "to": "implementation"
    }
  ]
}
