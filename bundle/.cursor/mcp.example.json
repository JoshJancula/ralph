{
  "mcpServers": [
    {
      "name": "ralph-mcp",
      "label": "Ralph plan runner host",
      "command": [
        "bash",
        "/path/to/workspace/.ralph/mcp-server.sh"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
        "RALPH_MCP_WORKSPACE": "/path/to/workspace"
      },
      "stdio": true
    }
  ]
}
