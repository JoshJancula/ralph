{
  "name": "qa",
  "model": "anthropic/claude-sonnet-4-6",
  "description": "Tests code changes and summarizes whether they meet the accepted criteria.",
  "rules": [".opencode/rules/no-emoji.md"],
  "skills": [".opencode/skills/repo-context/SKILL.md"],
  "output_artifacts": [
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/qa-handoff.md",
      "required": true,
      "kind": "review"
    },
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md",
      "required": false
    },
    {
      "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/qa-to-implementation.md",
      "required": false,
      "kind": "handoff",
      "to": "implementation"
    }
  ]
}
