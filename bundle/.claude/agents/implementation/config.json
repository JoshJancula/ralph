{
  "name": "implementation",
  "model": "claude-sonnet-4-6",
  "max_budget_usd": "5.00",
  "description": "Implements or changes code per architecture and tasks. Produces implementation-handoff.md summarizing what changed, how to verify, and open risks.",
  "rules": [
    ".claude/rules/no-emoji.md"
  ],
  "skills": [
    ".claude/skills/repo-context/SKILL.md"
  ],
  "output_artifacts": [
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/implementation-handoff.md",
      "required": true,
      "kind": "notes"
    },
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md",
      "required": false
    },
    {
      "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/implementation-to-qa.md",
      "required": false,
      "kind": "handoff",
      "to": "qa"
    }
  ]
}
