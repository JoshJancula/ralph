{
  "name": "security",
  "model": "claude-sonnet-4-6",
  "max_budget_usd": "1.00",
  "description": "Reviews changed code scanning for security vulnerabilities. Writes security.md summarizing findings and blocking issues.",
  "rules": [
    ".claude/rules/no-emoji.md"
  ],
  "skills": [
    ".claude/skills/repo-context/SKILL.md"
  ],
  "output_artifacts": [
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/security.md",
      "required": true,
      "kind": "review"
    },
    {
      "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/security-to-implementation.md",
      "required": false,
      "kind": "handoff",
      "to": "implementation"
    }
  ]
}
