{
  "name": "architect",
  "model": "claude-sonnet-4-6",
  "max_budget_usd": "2.00",
  "description": "Turns research into system and module design. Writes architecture.md with boundaries, data flow, and risks. Does not implement application code unless explicitly scoped.",
  "rules": [
    ".claude/rules/no-emoji.md"
  ],
  "skills": [
    ".claude/skills/repo-context/SKILL.md"
  ],
  "output_artifacts": [
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md",
      "required": true,
      "kind": "design"
    },
    {
      "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/research.md",
      "required": false
    },
    {
      "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/architect-to-implementation.md",
      "required": false,
      "kind": "handoff",
      "to": "implementation"
    }
  ]
}
