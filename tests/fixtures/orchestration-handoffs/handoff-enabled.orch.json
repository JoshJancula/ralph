{
  "name": "handoff-enabled",
  "namespace": "handoff-enabled",
  "description": "Sequential orchestration fixture with producer and consumer handoffs.",
  "stages": [
    {
      "id": "research",
      "agent": "research",
      "runtime": "cursor",
      "planTemplate": ".ralph/plan.template",
      "plan": ".ralph-workspace/orchestration-plans/{{ARTIFACT_NS}}/{{ARTIFACT_NS}}-01-research.plan.md",
      "sessionResume": false,
      "inputArtifacts": [],
      "outputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/research.md",
          "required": true,
          "kind": "research",
          "description": "Research summary, findings, open questions, and suggested next steps."
        }
      ],
      "artifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/research.md",
          "required": true
        }
      ]
    },
    {
      "id": "architect",
      "agent": "architect",
      "runtime": "cursor",
      "planTemplate": ".ralph/plan.template",
      "plan": ".ralph-workspace/orchestration-plans/{{ARTIFACT_NS}}/{{ARTIFACT_NS}}-02-architect.plan.md",
      "sessionResume": false,
      "inputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/research.md"
        }
      ],
      "outputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md",
          "required": true,
          "kind": "design",
          "description": "Technical architecture and design decisions derived from research."
        },
        {
          "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/architect-to-implementation.md",
          "required": false,
          "kind": "handoff",
          "to": "implementation",
          "description": "Handoff tasks for implementation stage with specific requirements from architecture."
        }
      ],
      "artifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md",
          "required": true
        },
        {
          "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/architect-to-implementation.md",
          "required": false
        }
      ]
    },
    {
      "id": "implementation",
      "agent": "implementation",
      "runtime": "cursor",
      "planTemplate": ".ralph/plan.template",
      "plan": ".ralph-workspace/orchestration-plans/{{ARTIFACT_NS}}/{{ARTIFACT_NS}}-03-implementation.plan.md",
      "sessionResume": false,
      "inputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/architecture.md"
        }
      ],
      "outputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/implementation-handoff.md",
          "required": true,
          "kind": "notes",
          "description": "Implementation handoff: what changed, how to verify, and follow-ups."
        },
        {
          "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/implementation-to-qa.md",
          "required": false,
          "kind": "handoff",
          "to": "qa",
          "description": "Handoff tasks for QA stage with testing instructions and expected behaviors."
        }
      ],
      "artifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/implementation-handoff.md",
          "required": true
        },
        {
          "path": ".ralph-workspace/handoffs/{{ARTIFACT_NS}}/implementation-to-qa.md",
          "required": false
        }
      ]
    },
    {
      "id": "code-review",
      "agent": "code-review",
      "runtime": "cursor",
      "planTemplate": ".ralph/plan.template",
      "plan": ".ralph-workspace/orchestration-plans/{{ARTIFACT_NS}}/{{ARTIFACT_NS}}-04-code-review.plan.md",
      "sessionResume": false,
      "inputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/implementation-handoff.md"
        }
      ],
      "outputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/code-review.md",
          "required": true,
          "kind": "review",
          "description": "Code review findings, risks, and required or suggested fixes."
        }
      ],
      "artifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/code-review.md",
          "required": true
        }
      ]
    },
    {
      "id": "qa",
      "agent": "qa",
      "runtime": "cursor",
      "planTemplate": ".ralph/plan.template",
      "plan": ".ralph-workspace/orchestration-plans/{{ARTIFACT_NS}}/{{ARTIFACT_NS}}-05-qa.plan.md",
      "sessionResume": false,
      "inputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/implementation-handoff.md"
        }
      ],
      "outputArtifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/qa.md",
          "required": true,
          "kind": "review",
          "description": "QA verification notes, test coverage, and sign-off or blocking issues."
        }
      ],
      "artifacts": [
        {
          "path": ".ralph-workspace/artifacts/{{ARTIFACT_NS}}/qa.md",
          "required": true
        }
      ]
    }
  ]
}
