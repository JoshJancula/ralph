#!/usr/bin/env python3
"""Run an executable script with stdin and stdout on a real PTY (portable; GNU script is inconsistent)."""
import os
import pty
import sys

def main() -> None:
    if len(sys.argv) < 2:
        print("usage: ralph-pty-exec /path/to/script", file=sys.stderr)
        sys.exit(2)
    runner = sys.argv[1]
    pid, _master_fd = pty.fork()
    if pid == 0:
        try:
            os.execvp(runner, [runner])
        except OSError as exc:
            print(exc, file=sys.stderr)
            sys.exit(127)
    _pid2, status = os.waitpid(pid, 0)
    if os.WIFEXITED(status):
        sys.exit(os.WEXITSTATUS(status))
    sys.exit(1)


if __name__ == "__main__":
    main()
