{
  "name": "ralph-dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/start-server.cjs",
    "build": "NODE_OPTIONS=--require=./scripts/angular-launch-server-stub.cjs ng build",
    "dev": "node --watch scripts/start-server.cjs",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:server && npm run test:angular",
    "test:server": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.ts --passWithNoTests",
    "test:angular": "vitest run",
    "test:cov": "npm run test:cov:server && npm run test:cov:angular",
    "test:cov:server": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.ts --coverage",
    "test:cov:angular": "vitest run --coverage",
    "serve:ssr:ralph-dashboard": "node scripts/start-server.cjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/marked": "^6.0.0",
    "express": "^5.1.0",
    "marked": "^15.0.0",
    "mermaid": "^11.13.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.4.0",
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "jest": "^30.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "zone.js": "^0.16.1"
  }
}
